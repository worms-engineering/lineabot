# MongoDB connection string. On Render use a MongoDB Atlas SRV URI, e.g.
# mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb://localhost:27017"

# Database name
DB_NAME="tennis_monitor"

# Comma-separated list of allowed frontend origins.
# In production set this to your Vercel URL, e.g. https://your-app.vercel.app
CORS_ORIGINS="*"

# OddsPapi v4 API key
ODDSPAPI_KEY="your-oddspapi-key"

# Telegram bot credentials
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# "true" to serve demo data without hitting OddsPapi
USE_MOCK_DATA="false"

# Minutes between automatic scans (optional, default 10)
REFRESH_MINUTES="10"
