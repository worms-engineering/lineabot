# MongoDB connection string. On Render use a MongoDB Atlas SRV URI, e.g.
# mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb://localhost:27017"

# Database name
DB_NAME="tennis_monitor"

# Comma-separated list of allowed frontend origins.
# In production set this to your Vercel URL, e.g. https://your-app.vercel.app
CORS_ORIGINS="*"

# API keys, one per data provider (switchable from the dashboard). You only need
# the key for the provider(s) you use.
#   THE_ODDS_API_KEY -> The Odds API (the-odds-api.com): major tournaments only
#   ODDSPAPI_KEY      -> OddsPapi (api.oddspapi.io): full calendar incl. Challenger/ITF
# If THE_ODDS_API_KEY is unset, the The-Odds-API provider falls back to ODDSPAPI_KEY.
THE_ODDS_API_KEY="your-the-odds-api-key"
ODDSPAPI_KEY="your-oddspapi-key"

# Telegram bot credentials
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# "true" to serve demo data without hitting the API
USE_MOCK_DATA="false"

# Minutes between automatic scans (optional, default 10). Each scan is gated by
# the tracking toggle (dashboard button / POST /api/tracking): while tracking is
# OFF the scan is skipped and no API credits are spent. Set to 0 to disable the
# scheduler entirely (scans only on-demand via /api/refresh).
REFRESH_MINUTES="10"
